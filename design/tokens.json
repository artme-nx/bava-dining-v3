{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "bark": {
        "950": { "$value": "#1A1410", "$type": "color" },
        "900": { "$value": "#241C16", "$type": "color" },
        "800": { "$value": "#362A20", "$type": "color" },
        "700": { "$value": "#4A3B2C", "$type": "color" }
      },
      "stone": {
        "100": { "$value": "#F1EADC", "$type": "color" },
        "300": { "$value": "#D3C6B0", "$type": "color" },
        "500": { "$value": "#9C8D78", "$type": "color" }
      },
      "canopy": {
        "300": { "$value": "#8B9B6E", "$type": "color" },
        "500": { "$value": "#5C6B47", "$type": "color" },
        "700": { "$value": "#3E4830", "$type": "color" },
        "900": { "$value": "#232A19", "$type": "color" }
      },
      "murva": {
        "300": { "$value": "#C285A6", "$type": "color" },
        "500": { "$value": "#93386A", "$type": "color" },
        "700": { "$value": "#5C1D42", "$type": "color" },
        "900": { "$value": "#2E0F21", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-spectral), 'Spectral', Georgia, serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-inter), 'Inter', system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "var(--font-jetbrains-mono), 'JetBrains Mono', 'SF Mono', monospace", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "180ms", "$type": "duration" },
        "base": { "$value": "320ms", "$type": "duration" },
        "reveal": { "$value": "0.9s", "$type": "duration" },
        "grow": { "$value": "1.6s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "organic": { "$value": "cubic-bezier(0.33, 1, 0.68, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "-0.01em", "$type": "dimension" },
      "label": { "$value": "0.18em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.bark.950}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.stone.100}", "$type": "color" },
    "card": { "$value": "{primitive.color.bark.900}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.stone.100}", "$type": "color" },
    "muted": { "$value": "{primitive.color.bark.900}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.stone.500}", "$type": "color" },
    "border": { "$value": "{primitive.color.bark.800}", "$type": "color" },
    "ring": { "$value": "{primitive.color.murva.500}", "$type": "color" },
    "radius": { "$value": "0.25rem", "$type": "dimension" },
    "accent": { "$value": "{primitive.color.murva.500}", "$type": "color" },
    "accent-dim": { "$value": "{primitive.color.murva.900}", "$type": "color" },
    "accent-soft": { "$value": "{primitive.color.murva.300}", "$type": "color" },
    "canopy": { "$value": "{primitive.color.canopy.500}", "$type": "color" },
    "canopy-soft": { "$value": "{primitive.color.canopy.300}", "$type": "color" },
    "canopy-deep": { "$value": "{primitive.color.canopy.900}", "$type": "color" },
    "spine-line": { "$value": "{primitive.color.bark.700}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "type-label": { "$value": "{primitive.font.mono}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-organic": { "$value": "{primitive.motion.ease.organic}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "duration-grow": { "$value": "{primitive.motion.duration.grow}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "ring-marker": {
      "size": { "$value": "2.75rem", "$type": "dimension" },
      "size-active": { "$value": "3.25rem", "$type": "dimension" },
      "border-width": { "$value": "1.5px", "$type": "dimension" }
    },
    "spine": {
      "width": { "$value": "2px", "$type": "dimension" },
      "glow": {
        "$value": "radial-gradient(circle, rgba(147, 56, 106, 0.35), transparent 70%)",
        "$type": "gradient"
      }
    },
    "chapter": {
      "kicker-size": { "$value": "0.72rem", "$type": "dimension" },
      "title-size": { "$value": "clamp(2.25rem, 5.5vw, 4rem)", "$type": "dimension" }
    }
  }
}
